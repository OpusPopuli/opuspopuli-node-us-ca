# =============================================================================
# Region-node production environment — REFERENCE DOCUMENTATION ONLY
# =============================================================================
#
# IMPORTANT: In normal operation you do NOT copy or fill in this file.
# `create-op-node bootstrap` writes every secret into the macOS Keychain
# and exports them into the launchd-managed Docker session via a
# LaunchAgent plist. `docker compose -f docker-compose-prod.yml up`
# inherits those vars from launchd automatically.
#
# This file exists for two cases only:
#   1. Operators driving compose by hand with `--env-file` for one-off
#      iteration (e.g. swapping a single SMTP setting without regenerating
#      a Keychain entry).
#   2. Newcomers who want a single-page list of every var the stack reads.
#
# Variables marked REQUIRED have no safe default. Variables marked SECRET
# must be high-entropy; rotate after any exposure. NEVER commit a filled-
# in copy of this file — `.env.production` is in `.gitignore`.
# =============================================================================

# -----------------------------------------------------------------------------
# Postgres (supabase/postgres image)
# -----------------------------------------------------------------------------
# DO NOT CHANGE. The bundled init scripts hardcode `ALTER DATABASE postgres
# SET …` for the JWT_SECRET / JWT_EXP GUCs that postgrest reads (see
# supabase/init/sql/01-jwt.sql). A non-`postgres` DB name silently breaks
# auth on first boot — gotrue/postgrest connect to a DB whose JWT GUCs were
# never set. Matches upstream Supabase self-hosting convention.
POSTGRES_DB=postgres
POSTGRES_PASSWORD=                 # REQUIRED SECRET — superuser + service role users

# -----------------------------------------------------------------------------
# pgsodium / supabase_vault
# -----------------------------------------------------------------------------
# 64-char hex (32 bytes). Generate: `openssl rand -hex 32`
# Mounted into the db container via pgsodium_getkey_env.sh. Losing this key
# destroys every secret in supabase_vault — back it up to Keychain.
PGSODIUM_ROOT_KEY=                 # REQUIRED SECRET

# -----------------------------------------------------------------------------
# JWT (gotrue / postgrest / storage / studio all sign with this)
# -----------------------------------------------------------------------------
# Min 32 chars. Generate: `openssl rand -base64 48`
JWT_SECRET=                        # REQUIRED SECRET
JWT_EXPIRY=3600

# Issue from JWT_SECRET — long-lived service tokens. The official Supabase
# self-hosting guide has a one-shot generator:
# https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
SUPABASE_ANON_KEY=                 # REQUIRED SECRET
SUPABASE_SERVICE_ROLE_KEY=         # REQUIRED SECRET

# -----------------------------------------------------------------------------
# Public-facing Supabase URL — what browsers + microservices hit
# -----------------------------------------------------------------------------
# Local dev: http://localhost:8000
# Via Cloudflare Tunnel: https://supabase.<region-node-domain>
SUPABASE_URL=http://localhost:8000
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=

# -----------------------------------------------------------------------------
# gotrue (auth)
# -----------------------------------------------------------------------------
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=Opus Populi

# -----------------------------------------------------------------------------
# postgrest
# -----------------------------------------------------------------------------
PGRST_DB_SCHEMAS=public,storage,graphql_public

# -----------------------------------------------------------------------------
# Studio (optional admin UI, enable with `--profile studio`)
# -----------------------------------------------------------------------------
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=                # REQUIRED SECRET if using studio
STUDIO_DEFAULT_ORGANIZATION=Opus Populi
STUDIO_DEFAULT_PROJECT=Region Node

# -----------------------------------------------------------------------------
# Ollama / inference
# -----------------------------------------------------------------------------
LLM_MODEL=qwen3.5:35b
EMBEDDINGS_MODEL=nomic-embed-text

# -----------------------------------------------------------------------------
# Cloudflare Tunnel (optional — leave blank for local-only mode)
# -----------------------------------------------------------------------------
TUNNEL_TOKEN=
