# =============================================================================
# .env.backup.example — contract between the backup overlay and the host env
# =============================================================================
#
# Copy to `.env.backup` (dev/UAT) or `.env.backup.prod` (Mac Studio) and fill
# in real values. Pass it to compose with --env-file:
#
#   docker compose -f docker-compose-prod.yml \
#                  -f docker-compose-backup.yml \
#                  --env-file .env.backup.prod \
#                  up -d opuspopuli-backup
#
# NEVER commit a filled-in .env.backup* — it holds the DB password + JWT
# secret. Only this .example (all placeholders) is checked in.
# -----------------------------------------------------------------------------

# --- Snapshot destination (REQUIRED) -----------------------------------------
# Host path bind-mounted to /backups inside the container. MUST be a real host
# filesystem path (ideally an external drive), never a docker named volume —
# named volumes were wiped in the 2026-06-06 disk-image-resize incident.
# `up` hard-fails if this is unset.
#
# DISASTER PROTECTION: for backups to survive a disk failure this must be a
# SEPARATE PHYSICAL DEVICE from Docker's data folder (a distinct /Volumes mount
# is not enough — APFS volumes on one disk share a failure domain). A path on
# the same disk still protects against corruption / bad migrations / accidental
# drops, but not disk loss. Prefer an external drive (e.g. /Volumes/T9/...).
BACKUPS_DIR_HOST=/Volumes/OpusPopuli/backups

# --- Main DB connection ------------------------------------------------------
# Password for the connecting role. NO default — an unset value hard-fails the
# `up` command (mirrors docker-compose-prod.yml's policy). Same value as the
# main stack's POSTGRES_PASSWORD.
POSTGRES_PASSWORD=change-me

# Everyday role for pg_dump and --quick restores. Defaults to `postgres`.
BACKUP_PGUSER=postgres

# Superuser role for restore-db.sh --full (drop/create + CREATE EXTENSION +
# JWT GUC re-apply). On the supabase/postgres image `postgres` is demoted to
# NOSUPERUSER, so --full must connect as the bootstrap superuser.
BACKUP_SUPERUSER=supabase_admin

# Host + database of the main cluster. Defaults match opuspopuli-db.
BACKUP_PGHOST=opuspopuli-db
BACKUP_PGDATABASE=postgres

# --- JWT GUCs (REQUIRED for --full restore) ----------------------------------
# A single-DB pg_dump does NOT capture `ALTER DATABASE ... SET`, and the
# supabase init scripts only run on first boot. restore-db.sh --full re-applies
# these after DROP+CREATE DATABASE so postgrest auth keeps working. Use the
# SAME jwt_secret as the running stack, or every issued/verified token breaks.
JWT_SECRET=change-me
JWT_EXP=3600

# --- Prompt-service DB backup (OPTIONAL) -------------------------------------
# Only needed on nodes running the docker-compose-prompt-service.yml overlay.
# backup-prompts-db.sh dumps the separate opuspopuli-prompts-db cluster and
# skips cleanly (logs `skipped`) when it's unreachable. Set to the prompts
# cluster's supabase_admin password (== PROMPTS_DB_PASSWORD in that overlay).
PROMPTS_DB_PASSWORD=
PROMPTS_PGHOST=opuspopuli-prompts-db
PROMPTS_PGUSER=supabase_admin
PROMPTS_PGDATABASE=prompt_service

# --- Scheduling / retention (OPTIONAL) ---------------------------------------
# Cron timezone (supercronic honors TZ). The hour in BACKUP_SCHEDULE is
# interpreted in this TZ.
TZ=America/Los_Angeles
# Backup schedules — 5-field cron. entrypoint.sh renders /crontab from these;
# defaults preserve the historical 03:00 (main) / 03:10 (prompts) daily runs.
# create-op-node writes BACKUP_SCHEDULE from `--backup-schedule`.
BACKUP_SCHEDULE=0 3 * * *
BACKUP_PROMPTS_SCHEDULE=10 3 * * *
# Days of snapshots to keep; older files pruned after a successful dump.
RETENTION_DAYS=7
# Git SHA baked into snapshot filenames for drift detection on restore.
GIT_SHA=unknown
# If true, ad-hoc runs block on the scheduler's lock; false = fail fast.
BACKUP_LOCK_WAIT=true

# --- supercronic build arg (OPTIONAL) ----------------------------------------
# Overrides the pinned supercronic version at build time. Changing this
# requires refreshing the SHA256 pins in backup/Dockerfile (see README).
SUPERCRONIC_VERSION=v0.2.31

# --- Off-site / R2 sync (OPTIONAL, not yet wired) ----------------------------
# R2 (rclone) sync of snapshots is deferred to a follow-up (see backup/README.md
# "Why no R2 sync yet"). These document the intended contract for when it lands;
# they are NOT read by the current backup scripts. Until then, off-site copies
# are handled manually from the host (Time Machine / rclone cron / aws s3 cp).
#RCLONE_REMOTE=r2
#RCLONE_R2_BUCKET=opuspopuli-backups
#RCLONE_R2_ACCESS_KEY_ID=
#RCLONE_R2_SECRET_ACCESS_KEY=
#RCLONE_R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
